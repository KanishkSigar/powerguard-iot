# ============================================================
# PowerGuard IoT — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# ============================================================

# ----------------------
# MQTT Broker
# ----------------------
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX=home/energy

# ----------------------
# InfluxDB
# ----------------------
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=my-super-secret-token
INFLUXDB_ORG=powerguard
INFLUXDB_BUCKET=energy_data

# ----------------------
# Tariff Configuration
# ----------------------
# Electricity rate in INR per kWh
TARIFF_RATE=6.50

# ----------------------
# Anomaly Detection
# ----------------------
# Power threshold for alerts (watts)
ANOMALY_POWER_THRESHOLD=2000
# Minimum seconds an appliance must be on to trigger "left on" alert
ANOMALY_LEFT_ON_SECONDS=7200

# ----------------------
# Telegram Alerts
# ----------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----------------------
# Email Alerts
# ----------------------
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=
EMAIL_PASSWORD=
EMAIL_RECIPIENT=

# ----------------------
# Server
# ----------------------
API_HOST=0.0.0.0
API_PORT=8000

# CORS Origins (Comma separated)
CORS_ORIGINS=*
